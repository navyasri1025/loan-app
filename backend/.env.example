# ─── API Settings ────────────────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ─── Database Settings ───────────────────────────────────────────────────────
# PostgreSQL (production default)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/loan_db
# Set to true to use SQLite for local development (no PostgreSQL required)
USE_SQLITE=true

# ─── Security ────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a strong random secret in production!
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── OpenRouter LLM (Required for AI agents) ─────────────────────────────────
# Get your free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324

# ─── OCR (Optional) ──────────────────────────────────────────────────────────
# Windows example: C:\Program Files\Tesseract-OCR\tesseract.exe
# Leave blank to use simulated OCR fallback (suitable for demo)
TESSERACT_CMD=
